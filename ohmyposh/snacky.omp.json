{
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#c386f1",
          "leading_diamond": "",
          "trailing_diamond": "",
          "properties": {
            "default_user_name": "snacky",
            "display_default": false
          }
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#ffffff",
          "background": "#ff479c",
          "properties": {
            "prefix": "  ",
            "style": "agnoster_short",
            "home_icon": " ",
            //"windows_registry_icon": "\uE0B1",
            "mapped_locations": [
              ["HKEY_CURRENT_USER", "\u0008\u0008 HKCU:"],
              ["HKEY_LOCAL_MACHINE", "\u0008\u0008 HKLM:"],
              ["\\LocalMachine", "\u0008\u0008 LocalMachine"],
              ["\\CurrentUser", "\u0008\u0008 CurrentUser"]
            ]
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#193549",
          "background": "#fffb38",
          "properties": {
            "display_stash_count": true,
            "display_upstream_icon": true
          }
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#ffffff",
          "background": "#6CA35E",
          "properties": {
            "prefix": " \uE718 "
          }
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#193549",
          "background": "#ffff66"
        },
        {
          "type": "exit",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#2e9599",
          "leading_diamond": "\u0000",
          "trailing_diamond": "",
          "properties": {
            "display_exit_code": false,
            "always_enabled": true,
            "error_color": "#f1184c",
            "color_background": true,
            "prefix": "<transparent></> "
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "shell",
          "style": "plain",
          "foreground": "#ffffff",
          "background": "#0077c2",
          "properties": {
            "prefix": "<#0077c2,transparent></>  ",
            "postfix": " ",
            "mapped_shell_names": { 
              "powershell": "posh"
             }
          }
        },
        {
          "type": "time",
          "style": "diamond",
          "foreground": "#ffffff",
          "background": "#2e9599",
          "leading_diamond": "",
          "trailing_diamond": ""
        }
      ]
    }
  ],
  "final_space": true
}
